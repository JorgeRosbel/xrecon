{
  "name": "@jorge-rosbel/xrecon",
  "version": "0.0.1",
  "type": "module",
  "description": "OSINT CLI tool for web reconnaissance - gather passive and active information about websites.",
  "bin": {
    "xrecon": "dist/index.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JorgeRosbel/xrecon.git"
  },
  "bugs": {
    "url": "https://github.com/JorgeRosbel/xrecon/issues"
  },
  "homepage": "https://github.com/JorgeRosbel/xrecon#readme",
  "keywords": [
    "osint",
    "reconnaissance",
    "security",
    "web",
    "cli",
    "pentest"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "preview": "pnpm run build && pnpm link",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "format": "prettier --write \"**/*.{js,ts}\"",
    "check": "prettier --check \"**/*.{js,ts}\""
  },
  "lint-staged": {
    "*.{js,ts,astro}": [
      "prettier --write"
    ]
  },
  "lint-staged:options": {
    "allowEmpty": true
  },
  "author": "Jorge Rosbel",
  "license": "MIT",
  "packageManager": "pnpm@10.18.1",
  "devDependencies": {
    "@esbuild-plugins/tsconfig-paths": "^0.1.2",
    "@playwright/test": "^1.58.2",
    "@types/inquirer": "^9.0.8",
    "@types/node": "^24.0.15",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/ui": "^3.2.4",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "playwright": "^1.58.2",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.5",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "axios": "1.13.6",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cheerio": "1.1.2",
    "commander": "^12.1.0",
    "fuse.js": "^7.1.0",
    "inquirer": "^12.7.0",
    "ora": "^9.0.0",
    "zod": "^4.1.13"
  }
}
